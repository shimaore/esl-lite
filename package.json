{
  "name": "esl-lite",
  "version": "3.1.2",
  "description": "Client for FreeSwitch Event System mod_event_socket",
  "homepage": "https://shimaore.github.io/esl-lite/",
  "keywords": [
    "freeswitch",
    "event",
    "typescript",
    "event socket",
    "mod_event_socket"
  ],
  "author": {
    "name": "Stéphane Alnet",
    "email": "stephane@shimaore.net",
    "url": "https://del.igh.tf/ul/stephane-alnet/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://g.rie.re/shimaore/esl-lite.git"
  },
  "type": "module",
  "module": "esl-lite.mjs",
  "main": "esl-lite.cjs",
  "types": "./types/src/esl-lite.d.ts",
  "files": [
    "esl-lite.cjs",
    "esl-lite.mjs",
    "./types/src/*.d.ts*"
  ],
  "exports": {
    ".": {
      "types": "./types/src/esl-lite.d.ts",
      "require": "./esl-lite.cjs",
      "import": "./esl-lite.mjs"
    }
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tsconfig/node24": "24.0.4",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.12.2",
    "@types/uuid": "11.0.0",
    "esbuild": "0.28.0",
    "eslint": "10.2.1",
    "pino": "10.3.1",
    "prettier": "3.8.3",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "uuid": "14.0.0"
  },
  "scripts": {
    "build": "node build.mjs",
    "prepublishOnly": "yarn install && yarn build && yarn syntax",
    "lint": "yarn prepublishOnly && eslint --fix src/**/*.ts && yarn postlint",
    "postlint": "prettier -w . && typedoc 'src/*.ts'",
    "syntax": "tsc",
    "test:live": "podman  build -f test/Dockerfile ."
  },
  "publishConfig": {
    "tag": "latest"
  },
  "packageManager": "yarn@4.3.1",
  "dependencies": {
    "ulidx": "2.4.1",
    "yocto-queue": "1.2.2"
  },
  "prettier": {
    "trailingComma": "es5",
    "semi": false,
    "singleQuote": true
  }
}
